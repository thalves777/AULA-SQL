CREATE TABLE guardioes (
    id     SERIAL PRIMARY KEY,
    nome   VARCHAR(50) NOT NULL,
    nivel  VARCHAR(20) NOT NULL,
    xp     INTEGER NOT NULL DEFAULT 0,
    status VARCHAR(20) DEFAULT 'ATIVO'
);

