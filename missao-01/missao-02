CREATE TABLE viloes (
    nome VARCHAR(50) NOT NULL,
    crimes_cometidos  VARCHAR(20) NOT NULL,
    patrimonio_roubado     INTEGER NOT NULL DEFAULT 0
);

-- Dados de exemplo para praticar os comandos DQL
